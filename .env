# Scraping
BANK_NAME=bbva
START_URL=https://www.bbva.com.co/
MAX_PAGES=20
REQUEST_TIMEOUT=15

# Retrieval / RAG
EMBEDDING_MODEL=intfloat/multilingual-e5-small
COLLECTION_NAME=bank_knowledge
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=8
FINAL_K=4
USE_RERANKER=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Gemini through LangChain
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_TEMPERATURE=0.2
MAX_NEW_TOKENS=500

# Conversation memory
N_HISTORY_MESSAGES=6
SQLITE_PATH=data/conversations.db

# Paths
RAW_DATA_PATH=data/raw/pages.jsonl
PROCESSED_DATA_PATH=data/processed/chunks.jsonl
CHROMA_PATH=data/chroma
